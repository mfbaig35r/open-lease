# gpu-orchestrator sample environment.
# Copy to `.env` (which is gitignored) and fill in your values:
#   cp .env.example .env
#
# Precedence (highest wins): CLI flags > env vars > .env > ./gpu-orchestrator.toml
# > ~/.gpu-orchestrator/config.toml > defaults. Secrets are never logged or written to state.db.

# --- Credentials --------------------------------------------------------------

# Required for the RunPod provider. Needs pod create/delete permission.
# Get one at https://www.runpod.io/console/user/settings (real GPUs cost money).
RUNPOD_API_KEY=

# Optional. The catalog models (Qwen3) are public, so a token is not required,
# but it avoids Hugging Face anonymous rate limits on downloads and is mandatory
# for gated models (e.g. Llama). https://huggingface.co/settings/tokens
HF_TOKEN=

# --- Common settings (uncomment to override the defaults) ---------------------
# All app settings use the GPU_ORCH_ prefix.

# Per-install namespace. Scopes the orphan sweep so it never touches another
# install's pods. Defaults to this machine's sanitized hostname.
# GPU_ORCH_NAMESPACE=my-laptop

# Where deployment state lives. Defaults to ~/.gpu-orchestrator/state.db
# GPU_ORCH_STATE_DB=/absolute/path/to/state.db

# --- Loop cadences, in seconds (defaults shown) -------------------------------
# GPU_ORCH_RECONCILE_INTERVAL=10
# GPU_ORCH_HEALTH_POLL_INTERVAL=30
# GPU_ORCH_HEALTH_FAILURE_THRESHOLD=3
# GPU_ORCH_ORPHAN_SWEEP_INTERVAL=300
# GPU_ORCH_ORPHAN_GRACE_PERIOD=120

# --- Retry / backoff (defaults shown) -----------------------------------------
# GPU_ORCH_RETRY_MAX_ATTEMPTS=3
# GPU_ORCH_RETRY_BACKOFF_MIN=10
# GPU_ORCH_RETRY_BACKOFF_MAX=60

# --- Per-stage timeout budgets, in seconds (defaults shown) -------------------
# GPU_ORCH_TIMEOUT_PROVISIONING=300
# GPU_ORCH_TIMEOUT_BOOTING=300
# GPU_ORCH_TIMEOUT_DOWNLOAD=1800
# GPU_ORCH_TIMEOUT_STARTING=300

# --- Proxy (step 8; defaults shown) -------------------------------------------
# GPU_ORCH_PROXY_HOST=localhost
# GPU_ORCH_PROXY_PORT=8080
